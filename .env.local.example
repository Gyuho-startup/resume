# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_EXPORT_PASS=price_your-export-pass-price-id

# PDF Renderer (Cloudflare Worker)
PDF_RENDERER_URL=https://your-worker.workers.dev
PDF_RENDERER_TOKEN=your-secure-token-here

# Optional: Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# Sentry (error monitoring)
# Server-side DSN (not exposed to browser)
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Client-side DSN (can be public — no secrets in DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# For source map uploads (CI/CD only, not needed locally)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
